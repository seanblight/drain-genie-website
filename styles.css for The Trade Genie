* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  font-family: Arial, Helvetica, sans-serif;
  background: #06111f;
  color: white;
}

a {
  color: inherit;
}

/* HEADER */

.site-header {
  width: 100%;
  background: rgba(3, 12, 24, 0.96);
  border-bottom: 1px solid rgba(30,144,255,0.28);
  box-shadow: 0 12px 40px rgba(0,0,0,0.35);
  position: sticky;
  top: 0;
  z-index: 999;
  backdrop-filter: blur(12px);
}

.header-inner {
  max-width: 1420px;
  margin: 0 auto;
  padding: 10px 28px;
  display: flex;
  align-items: center;
  gap: 26px;
}

.site-logo {
  width: 210px;
  height: auto;
  display: block;
}

.header-menu {
  display: flex;
  gap: 24px;
  margin-left: auto;
}

.header-menu a {
  color: #f2f7ff;
  text-decoration: none;
  font-weight: 900;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  opacity: 0.9;
  transition: 0.2s ease;
}

.header-menu a:hover {
  color: #35d0ff;
}

.drain-genie-btn {
  background: linear-gradient(135deg, #35d0ff, #0b8cff);
  color: #071827 !important;
  padding: 10px 14px;
  border-radius: 999px;
  opacity: 1 !important;
  box-shadow: 0 10px 28px rgba(53,208,255,0.25);
}

.header-call {
  background: linear-gradient(135deg, #0b8cff, #005eea);
  padding: 13px 20px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 900;
  margin-left: 14px;
  white-space: nowrap;
  box-shadow: 0 14px 35px rgba(0,120,255,0.38);
  transition: 0.2s ease;
}

.header-call:hover,
.main-call:hover,
.drain-genie-card a:hover {
  transform: translateY(-2px);
  filter: brightness(1.08);
}

/* HERO */

.hero-section {
  min-height: 82vh;
  padding: 95px 28px 90px;

  background:
    linear-gradient(
      90deg,
      rgba(3,12,24,0.98) 0%,
      rgba(3,12,24,0.88) 35%,
      rgba(3,12,24,0.45) 60%,
      rgba(3,12,24,0.1) 100%
    ),
    url("/images/trade-genie-hero.png");

  background-size: cover;
  background-position: center right;
}

.hero-content {
  max-width: 1180px;
  margin: 0 auto;
}

.area-tag,
.blue-title {
  color: #21a3ff;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.8px;
}

.hero-section h1 {
  font-size: clamp(48px, 6vw, 88px);
  line-height: 0.95;
  margin: 14px 0 24px;
  text-transform: uppercase;
  letter-spacing: -2px;
}

.hero-section h1 span {
  color: #35d0ff;
  text-shadow: 0 0 28px rgba(53,208,255,0.35);
}

.hero-copy {
  max-width: 720px;
  font-size: 20px;
  line-height: 1.7;
  color: #eaf3ff;
}

.trust-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin: 32px 0;
}

.trust-row p {
  margin: 0;
  font-weight: 800;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(33,163,255,0.26);
  padding: 10px 14px;
  border-radius: 999px;
}

.hero-buttons {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.main-call {
  background: linear-gradient(135deg, #0b8cff, #005eea);
  padding: 18px 30px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 900;
  box-shadow: 0 18px 45px rgba(0,120,255,0.42);
  transition: 0.2s ease;
}

.outline-btn {
  padding: 18px 30px;
  border: 2px solid rgba(255,255,255,0.85);
  border-radius: 10px;
  text-decoration: none;
  font-weight: 900;
  background: rgba(0,0,0,0.18);
  transition: 0.2s ease;
}

.outline-btn:hover {
  background: white;
  color: #07111f;
}

/* SERVICES */

.service-strip {
  max-width: 1160px;
  margin: -48px auto 0;
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  background: rgba(5, 24, 44, 0.96);
  border-radius: 18px;
  overflow: hidden;
  border: 1px solid rgba(33,163,255,0.28);
  box-shadow: 0 25px 70px rgba(0,0,0,0.38);
}

.service-box {
  padding: 25px 16px;
  text-align: center;
  border-right: 1px solid rgba(255,255,255,0.08);
  text-decoration: none;
  transition: 0.2s ease;
}

.service-box:last-child {
  border-right: none;
}

.service-box:hover {
  background: rgba(11,137,255,0.18);
  transform: translateY(-3px);
}

.icon {
  font-size: 32px;
  margin-bottom: 10px;
}

.service-box h3 {
  margin: 0 0 7px;
  font-size: 13px;
  text-transform: uppercase;
}

.service-box p {
  font-size: 13px;
  color: #cfe2ff;
  line-height: 1.45;
  margin: 0;
}

/* ABOUT */

.about-section {
  max-width: 1160px;
  margin: 85px auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 1.45fr 0.9fr;
  gap: 55px;
  align-items: center;
}

.big-brand-line {
  font-size: clamp(34px, 4vw, 52px);
  margin: 0 0 10px;
  text-shadow: 0 0 24px rgba(33,163,255,0.28);
}

.about-section h2 {
  font-size: clamp(32px, 4vw, 48px);
  margin: 0 0 16px;
  line-height: 1.1;
}

.section-copy {
  color: #cfe2ff;
  line-height: 1.75;
  font-size: 18px;
}

.help-card {
  background: linear-gradient(135deg, #075cbd, #003d96);
  padding: 34px;
  border-radius: 20px;
  box-shadow: 0 25px 70px rgba(0,0,0,0.35);
}

.help-card p {
  margin-top: 0;
  font-weight: 900;
  text-transform: uppercase;
}

.help-card span {
  color: #e9f4ff;
  line-height: 1.5;
}

.help-card h3 {
  font-size: 40px;
  margin: 18px 0;
}

.help-card a {
  display: inline-block;
  background: #087cff;
  padding: 13px 22px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 900;
}

/* DRAIN GENIE SECTION */

.drain-genie-section {
  background:
    radial-gradient(circle at top left, rgba(53,208,255,0.16), transparent 35%),
    linear-gradient(135deg, #04101f, #08243d);

  padding: 85px 24px;
}

.drain-genie-inner {
  max-width: 1160px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.35fr 0.9fr;
  gap: 45px;
  align-items: center;
}

.drain-genie-inner h2 {
  font-size: clamp(34px, 4vw, 52px);
  margin-bottom: 18px;
}

.drain-genie-inner p {
  color: #dbeafe;
  line-height: 1.75;
  font-size: 18px;
}

.drain-genie-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(53,208,255,0.25);
  border-radius: 22px;
  padding: 32px;
  box-shadow: 0 25px 70px rgba(0,0,0,0.28);
}

.drain-genie-card h3 {
  font-size: 28px;
  margin-top: 0;
  margin-bottom: 12px;
  color: #35d0ff;
}

.drain-genie-card p {
  font-size: 16px;
  margin-bottom: 24px;
}

.drain-genie-card a {
  display: inline-block;
  background: linear-gradient(135deg, #35d0ff, #0b8cff);
  color: #071827;
  padding: 14px 22px;
  border-radius: 12px;
  text-decoration: none;
  font-weight: 900;
  transition: 0.2s ease;
}

/* SERVICES SECTION */

.services-section {
  padding: 90px 24px;
  background: #0b1728;
  text-align: center;
}

.services-section h2 {
  font-size: 44px;
  margin-bottom: 45px;
}

.services-grid {
  max-width: 1160px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.large-service-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  padding: 28px;
  text-align: left;
  transition: 0.25s ease;
}

.large-service-card:hover {
  transform: translateY(-4px);
  border-color: #35d0ff;
}

.large-service-card h3 {
  margin-top: 0;
  color: #35d0ff;
  font-size: 22px;
}

.large-service-card p {
  color: #dbeafe;
  line-height: 1.7;
}

/* AREAS */

.areas-section {
  background: #071827;
  padding: 90px 24px;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
}

.section-tag {
  color: #35d0ff;
  font-weight: 800;
  text-transform: uppercase;
}

.areas-section h2 {
  font-size: 48px;
  margin-bottom: 20px;
}

.service-areas-intro {
  max-width: 850px;
  color: #dbeafe;
  line-height: 1.75;
  margin-bottom: 45px;
}

.suburb-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.suburb-card {
  background: rgba(255,255,255,0.05);
  border-radius: 18px;
  padding: 26px;
  border: 1px solid rgba(255,255,255,0.08);
}

.suburb-card h3 {
  color: #35d0ff;
  margin-top: 0;
}

/* WHY US */

.why-us-section {
  background: #0b1728;
  padding: 90px 24px;
  text-align: center;
}

.why-us-section h2 {
  font-size: 46px;
  margin-bottom: 45px;
}

.why-grid {
  max-width: 1160px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.why-grid div {
  background: rgba(255,255,255,0.05);
  padding: 28px;
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,0.08);
}

.why-grid h3 {
  color: #35d0ff;
}

/* REVIEWS */

.reviews-section {
  padding: 90px 24px;
  text-align: center;
  background: #07111f;
}

.reviews-section h2 {
  font-size: 44px;
  margin-bottom: 40px;
}

.reviews-grid {
  max-width: 1080px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.reviews-grid div {
  background: #0e2139;
  padding: 28px;
  border-radius: 18px;
  border: 1px solid rgba(33,163,255,0.24);
}

.reviews-grid p {
  color: #e6eefc;
  line-height: 1.65;
}

.stars {
  color: #ffd54a !important;
  font-size: 22px;
}

/* SEO */

.seo-section {
  padding: 90px 24px;
  background: #0b1728;
  text-align: center;
}

.seo-section h2 {
  font-size: 44px;
  margin-bottom: 24px;
}

.seo-section p {
  max-width: 900px;
  margin: 0 auto;
  color: #dbeafe;
  line-height: 1.8;
  font-size: 18px;
}

/* FOOTER */

footer {
  text-align: center;
  padding: 40px 24px 90px;
  background: #030b14;
  color: #9fb3c8;
}

footer a {
  color: #35d0ff;
  font-weight: 900;
  text-decoration: none;
}

.footer-logo {
  width: 170px;
  margin-bottom: 18px;
}

/* MOBILE */

@media (max-width: 1100px) {

  .services-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .why-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .suburb-grid {
    grid-template-columns: 1fr;
  }

  .drain-genie-inner {
    grid-template-columns: 1fr;
  }

  .about-section {
    grid-template-columns: 1fr;
  }

  .reviews-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 700px) {

  .header-menu {
    display: none;
  }

  .header-inner {
    justify-content: space-between;
    padding: 9px 16px;
  }

  .site-logo {
    width: 150px;
  }

  .header-call {
    padding: 11px 12px;
    font-size: 12px;
    margin-left: 0;
  }

  .hero-section {
    min-height: auto;
    padding: 70px 18px 85px;

    background:
      linear-gradient(
        90deg,
        rgba(3,12,24,0.97),
        rgba(3,12,24,0.78)
      ),
      url("/images/trade-genie-hero.png");

    background-size: cover;
    background-position: center;
  }

  .hero-copy {
    font-size: 17px;
  }

  .service-strip {
    grid-template-columns: repeat(2, 1fr);
    margin: -42px 14px 0;
  }

  .services-grid {
    grid-template-columns: 1fr;
  }

  .why-grid {
    grid-template-columns: 1fr;
  }

  .main-call,
  .outline-btn {
    width: 100%;
    text-align: center;
  }
}
